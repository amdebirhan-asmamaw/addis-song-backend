{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,

    "noImplicitAny": false
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

